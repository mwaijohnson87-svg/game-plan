# Supabase (required for game progress and leaderboard)
# URL should be your project root, e.g. https://your-project.supabase.co (no /rest/v1 suffix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Dev user profile id for local persistence (create a row in profiles table with this UUID)
NEXT_PUBLIC_DEV_USER_ID=your-user-uuid
